// ──────────────────────────────────────────────
// Prisma schema — Puducherry RTO database
// ──────────────────────────────────────────────
// SQLite for development, PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── User ──
model User {
  id              String   @id @default(cuid())
  email           String   @unique
  mobile          String   @unique
  passwordHash    String
  name            String
  role            String   @default("CITIZEN")
  isEmailVerified Boolean  @default(false)
  isMobileVerified Boolean @default(false)
  aadhaarLastFour String?
  digilockerId    String?  @unique
  googleId        String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications    Application[]
  appointments    Appointment[]
  vehicles        Vehicle[]
  licenses        License[]
  payments        Payment[]
  notifications   Notification[]

  @@map("users")
}

// ── Vehicle ──
model Vehicle {
  id              String   @id @default(cuid())
  registrationNo  String   @unique
  chassisNo       String
  engineNo        String
  make            String
  model           String
  variant         String?
  manufactureYear Int
  fuelType        String
  color           String
  ownerName       String
  ownerAddress    String
  insuranceUpto   DateTime
  puccUpto        DateTime?
  taxPaidUpto     DateTime
  fitnessUpto     DateTime @default(now())
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner           User     @relation(fields: [ownerId], references: [id])
  ownerId         String

  @@index([ownerId])
  @@index([status])
  @@map("vehicles")
}

// ── License ──
model License {
  id        String   @id @default(cuid())
  licenseNo String   @unique
  type      String   @default("MCWG")
  name      String
  dob       DateTime
  bloodGroup String?
  address   String
  issueDate DateTime
  expiryDate DateTime
  status    String   @default("ACTIVE")
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holder    User     @relation(fields: [holderId], references: [id])
  holderId  String

  @@index([holderId])
  @@index([status])
  @@map("licenses")
}

// ── Application ──
model Application {
  id          String    @id @default(cuid())
  type        String
  status      String    @default("DRAFT")
  formData    String?   // JSON string for SQLite compatibility
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applicant   User      @relation(fields: [applicantId], references: [id])
  applicantId String
  documents   Document[]
  payment     Payment?

  @@index([applicantId])
  @@index([status])
  @@index([type])
  @@map("applications")
}

// ── Document ──
model Document {
  id            String   @id @default(cuid())
  type          String
  fileUrl       String
  uploadedAt    DateTime @default(now())

  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String

  @@map("documents")
}

// ── Appointment ──
model Appointment {
  id          String   @id @default(cuid())
  date        DateTime
  timeSlot    String
  purpose     String
  status      String   @default("SCHEDULED")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applicant   User     @relation(fields: [applicantId], references: [id])
  applicantId String

  @@index([applicantId])
  @@index([status])
  @@index([date])
  @@map("appointments")
}

// ── Payment ──
model Payment {
  id              String    @id @default(cuid())
  amount          Float
  transactionId   String    @unique   // GRN (Government Reference Number)
  gatewayRefNo    String?             // BRN (Bank Reference Number)
  paymentMethod   String?             // UPI, Card, Net Banking
  status          String    @default("PENDING")
  paidAt          DateTime?
  createdAt       DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  userId        String
  applicationId String? @unique
  application   Application? @relation(fields: [applicationId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([paidAt])
  @@map("payments")
}

// ── Notification ──
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("INFO")
  channel   String   @default("IN_APP")  // IN_APP, SMS, EMAIL
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  userId    String

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
