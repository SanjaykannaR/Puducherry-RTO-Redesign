# ── Production Environment Config ──
# Copy this to .env.production and fill in real values.
# DO NOT commit .env.production to git.

PORT=5000
DATABASE_URL="file:./prod.db"
JWT_SECRET="<REPLACE with a secure random string — 32+ chars>"
CORS_ORIGIN="https://your-domain.gov.in"
NODE_ENV="production"

# OAuth — replace with real keys
DIGILOCKER_CLIENT_ID="<get from API Setu partner portal>"
DIGILOCKER_CLIENT_SECRET="<get from API Setu partner portal>"
DIGILOCKER_REDIRECT_URI="https://your-domain.gov.in/api/auth/digilocker/callback"

GOOGLE_CLIENT_ID="<get from Google Cloud Console>"
GOOGLE_CLIENT_SECRET="<get from Google Cloud Console>"
GOOGLE_REDIRECT_URI="https://your-domain.gov.in/api/auth/google/callback"

# Gemini API (optional — for RTO AI assistant)
GEMINI_API_KEY="<your key>"
